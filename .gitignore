# =============================================================================
# Terraform
# =============================================================================
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfstate.backup
crash.log
crash.*.log

# Variable files (may contain secrets)
*.tfvars
*.tfvars.json
!*.tfvars.example

# CLI config
.terraformrc
terraform.rc

# Plan output
*.tfplan
*.tfplan.*

# Lock file: keep committed by default (uncomment to ignore)
# .terraform.lock.hcl

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# =============================================================================
# Packer
# =============================================================================
packer_cache/
**/packer_cache/
*.box

# Packer variable files (may contain secrets)
*.pkrvars.hcl
*.auto.pkrvars.hcl
!*.pkrvars.hcl.example

# Packer manifest output
manifest.json

# Packer crash logs
crash.log

# =============================================================================
# AWS / Secrets
# =============================================================================
.aws/
*.pem
*.ppk
credentials
*.key

# =============================================================================
# Editors / OS
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Logs
# =============================================================================
*.log
