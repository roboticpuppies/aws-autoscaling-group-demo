{
  "permissions": {
    "allow": [
      "mcp__terraform__get_latest_provider_version",
      "mcp__terraform__search_modules",
      "mcp__aws-knowledge-mcp-server__aws___search_documentation",
      "mcp__terraform__get_module_details",
      "Bash(packer fmt *)",
      "Bash(packer validate *)",
      "Bash(terraform fmt *)",
      "Bash(terragrunt hcl *)",
      "Bash(terraform -chdir=terraform/modules/app init -backend=false -input=false)",
      "Bash(terraform -chdir=terraform/modules/app validate)",
      "Bash(terraform -chdir=terraform/modules/shared-infra fmt -check -recursive)",
      "Bash(terraform -chdir=terraform/modules/app fmt -check -recursive)"
    ]
  },
  "enabledMcpjsonServers": [
    "terraform",
    "aws-knowledge-mcp-server"
  ]
}
