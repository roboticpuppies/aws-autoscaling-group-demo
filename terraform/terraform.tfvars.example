# =============================================================================
# General
# =============================================================================

project_name = "myproject"
environment  = "production"
aws_region   = "ap-southeast-3"

# Per-app identifier. Multiple apps can share project_name + environment;
# app_name namespaces SSM parameters, per-app resource names, and the on-instance
# compose directory (/home/ubuntu/<app_name>).
app_name = "myapp"

# =============================================================================
# VPC
# =============================================================================

vpc_cidr            = "10.0.0.0/16"
azs                 = ["ap-southeast-3a", "ap-southeast-3b", "ap-southeast-3c"]
public_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]

# =============================================================================
# Security
# =============================================================================

ssh_allowed_cidrs = ["203.0.113.0/24"]
app_port          = 8080
health_check_path = "/health"

# =============================================================================
# EC2 / ASG
# =============================================================================

ami_id                    = "ami-0123456789abcdef0" # Replace with your Packer-built AMI ID
instance_type             = "t3.medium"
key_name                  = "my-key-pair"
asg_min_size              = 1
asg_max_size              = 3
asg_desired_capacity      = 2
health_check_grace_period = 300

# =============================================================================
# SSM / Application Config
# =============================================================================

# Note: SSM parameter prefix is auto-derived as /<project_name>/<environment>/<app_name>
# e.g., /myproject/production/myapp
docker_image_repo = "123456789012.dkr.ecr.ap-southeast-3.amazonaws.com/myapp"
docker_image_tag  = "v1.0.0"

app_env_vars = {
  NODE_ENV     = "production"
  DATABASE_URL = "postgresql://user:pass@host:5432/db"
  API_KEY      = "sk-your-api-key"
}
